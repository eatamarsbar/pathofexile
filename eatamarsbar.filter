# ------------------------------
# -- Vendor
# ------------------------------
# Jeweller's Orb
Show
    Sockets 6
    SetBackgroundColor 0 73 0
# Quality (3x20% = Orb of Alchemy)
Show
    Quality 20
    SetBackgroundColor 0 73 0
# Chromatic Orb
Show
    LinkedSockets >= 3
    SocketGroup RGB
    SetBackgroundColor 0 73 0

