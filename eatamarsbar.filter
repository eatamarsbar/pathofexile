# Pick-up:  0 191 0 | 114 0 83
# Desirable: 254 213 0 | 0 0 128 | 0 73 0
# Skip: 191 0 0

# ------------------------------
# -- Generic
# ------------------------------
Show
    Rarity Unique
    SetFontSize 40

# Flasks
Show
    Class "Utility Flask"
Hide
    BaseType Flask
    Quality < 10
Show
    BaseType Flask

# Gems
Show
    Class Gem
    Quality >= 10
    SetTextColor 128 179 254
    SetBackgroundColor 0 0 128
Show
    Class Gem

# Currency
Hide
    BaseType "Scroll of Wisdom"
Show
    BaseType "Chaos Orb" "Orb of Alchemy" "Orb of Fusing" "Jeweller's Orb" "Chromatic Orb" "Cartographer's Chisel"
    SetTextColor 254 128 222
    SetBackgroundColor 114 0 83
Show
    Class Map Pantheon
    SetBackgroundColor 114 0 83
Show
    Class Quest
    SetFontSize 40
Show
    Class Currency Hideout Microtransaction Card Labyrinth Piece Abyss

# ------------------------------
# -- Interests
# ------------------------------
# GGBBQ
Show
    LinkedSockets >= 5
    SetBorderColor 0 191 0
    SetFontSize 40

# Rare Bases
Show
    BaseType "Prismatic Ring" "Steel Ring" "Spiked Gloves" "Gripped Gloves" "Fingerless Silk Gloves"
    SetBorderColor 0 191 0

Show
    Class Jewel
    SetBackgroundColor 0 0 128

